# Database connection
DB_HOST=127.0.0.1
DB_PORT=3306
# DB_NAME is optional. If set, it becomes the initial default database.
# If empty or omitted, you can select a database at runtime via the use_database tool.
DB_NAME=your_database_name
DB_USER=your_mysql_user
DB_PASS=your_mysql_password

# PIN hash for access level changes (bcrypt)
# Generate with: php -r "echo password_hash('your_pin', PASSWORD_BCRYPT) . PHP_EOL;"
ACCESS_PIN_HASH=

# HMAC secret for signing storage/access_level.json (64-char hex string)
# Generate with: php -r "echo bin2hex(random_bytes(32)) . PHP_EOL;"
HMAC_SECRET=
